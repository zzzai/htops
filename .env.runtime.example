# Optional runtime overrides for standalone Hetang workers and query API.
# htops auto-detects the repo root by default, so these path overrides are usually unnecessary.
# HTOPS_CONFIG_PATH=/path/to/htops/htops.json
HTOPS_STATE_DIR=/root/.htops
# HETANG_ROOT_DIR=/path/to/htops
# HETANG_RUNTIME_ENV_FILE=/path/to/htops/.env.runtime
HETANG_GATEWAY_ROOT_DIR=/path/to/gateway
HETANG_GATEWAY_SERVICE_NAME=gateway.service
HETANG_GATEWAY_DIST_ENTRY=/path/to/gateway/dist/index.js
HETANG_MESSAGE_SEND_ENTRY=/path/to/gateway/dist/index.js
HETANG_BRIDGE_HOST=127.0.0.1
HETANG_BRIDGE_PORT=18891
HETANG_BRIDGE_TOKEN=replace-with-local-bridge-token
# HETANG_WECOM_GROUP_SENDER=/path/to/htops/ops/wecom-send-group.mjs
HETANG_WECOM_BOT_ID=replace-with-bot-id
HETANG_WECOM_BOT_SECRET=replace-with-bot-secret
